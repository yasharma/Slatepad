{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-background-color",
    "sql:default",
    "sql:allow-execute",
    "dialog:default",
    "fs:default",
    "fs:allow-cache-read-recursive",
    "process:default",
    "updater:default"
  ]
}
